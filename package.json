{
  "name": "airhub-beijing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "京翼机场中枢 AirHub-Beijing — 机场运行数据可视化大屏",
  "scripts": {
    "dev": "vite --host",
    "dev:open": "vite --open",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.cjs,.ts,.tsx --fix --quiet",
    "lint:check": "eslint . --ext .vue,.js,.cjs,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{vue,ts,js,scss,json}\"",
    "stylelint": "stylelint \"src/**/*.scss\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@kjgl77/datav-vue3": "^1.2.2",
    "@vueuse/core": "^11.3.0",
    "axios": "^1.7.9",
    "echarts": "^5.5.1",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "sass": "^1.83.0",
    "stylelint": "^16.12.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  },
  "lint-staged": {
    "*.{vue,js,cjs,ts,tsx}": "eslint --fix",
    "*.{vue,scss,css}": "stylelint --fix",
    "*.{vue,ts,js,scss,json,md}": "prettier --write"
  }
}
